{
	"name": "@rewritetoday/adapters",
	"version": "0.1.0",
	"description": "Webhook adapters for Rewrite.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"bun": "./src/index.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./webhooks": {
			"types": "./src/webhooks/index.ts",
			"bun": "./src/webhooks/index.ts",
			"import": "./dist/webhooks/index.js"
		},
		"./webhooks/*": {
			"types": "./src/webhooks/*.ts",
			"bun": "./src/webhooks/*.ts",
			"import": "./dist/webhooks/*.js"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"license": "Apache-2.0",
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false,
	"engines": {
		"node": ">=18",
		"bun": ">=1.0.0"
	},
	"scripts": {
		"build": "rm -rf dist && bun run gen:version && tsc -p tsconfig.json",
		"types": "tsc -p tsconfig.json --emitDeclarationOnly",
		"typecheck": "bun run gen:version && tsc -p tsconfig.json --noEmit",
		"gen:version": "bun run scripts/version.ts",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@rewritetoday/zod": "^1.0.0",
		"zod": "^4.3.6"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
