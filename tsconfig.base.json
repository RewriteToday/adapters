{
	"compilerOptions": {
		"baseUrl": ".",
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022", "DOM"],
		"strict": true,
		"skipLibCheck": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"composite": true,
		"noEmitOnError": true,
		"moduleDetection": "force",
		"verbatimModuleSyntax": true,
		"resolveJsonModule": true,
		"allowSyntheticDefaultImports": true,
		"types": ["bun"],
		"customConditions": ["bun"],
		"paths": {
			"@rewritetoday/adapters": ["packages/core/src/index.ts"],
			"@rewritetoday/adapters/webhooks": [
				"packages/core/src/webhooks/index.ts"
			],
			"@rewritetoday/edge": ["packages/edge/src/index.ts"],
			"@rewritetoday/elysia": ["packages/elysia/src/index.ts"],
			"@rewritetoday/express": ["packages/express/src/index.ts"],
			"@rewritetoday/fastify": ["packages/fastify/src/index.ts"],
			"@rewritetoday/hono": ["packages/hono/src/index.ts"]
		},
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true
	}
}
